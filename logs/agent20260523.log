pected):\n        """对三种解法统一验证"""\n        for name, fn in self.solutions:\n            with self.subTest(solution=name):\n                result = fn(height)\n                self.assertEqual(\n                    result, expected,\n                    f"{name}: input={height}, expected={expected}, got={result}"\n                )\n\n    # ---- 基础用例 ----\n    def test_leetcode_classic(self):\n        """LeetCode 经典示例"""\n        self._test_all([0, 1, 0, 2, 1, 0, 1, 3, 2, 1, 2, 1], 6)\n\n    def test_descending(self):\n        """单调递减 — 接不到水"""\n        self._test_all([5, 4, 3, 2, 1], 0)\n\n    def test_ascending(self):\n        """单调递增 — 接不到水"""\n        self._test_all([1, 2, 3, 4, 5], 0)\n\n    def test_valley(self):\n        """完美山谷"""\n        self._test_all([3, 0, 2, 0, 4], 7)\n\n    def test_flat(self):\n        """全相等"""\n        self._test_all([2, 2, 2, 2], 0)\n\n    def test_single_bucket(self):\n        """只有一个凹槽"""\n        self._test_all([3, 0, 3], 3)\n\n    # ---- 边界用例 ----\n    def test_empty(self):\n        """空数组"""\n        self._test_all([], 0)\n\n    def test_single_element(self):\n        """单元素"""\n        self._test_all([5], 0)\n\n    def test_two_elements(self):\n        """两个元素"""\n        self._test_all([3, 1], 0)\n        self._test_all([1, 3], 0)\n\n    def test_all_zeros(self):\n        """全是0"""\n        self._test_all([0, 0, 0], 0)\n\n    # ---- 复杂用例 ----\n    def test_multiple_valleys(self):\n        """多峰多谷"""\n        self._test_all([2, 0, 3, 0, 1, 0, 2], 7)\n\n    def test_plateau(self):\n        """带有平台"""\n        self._test_all([4, 2, 2, 2, 3], 3)\n\n    def test_tall_walls(self):\n        """两侧高墙"""\n        self._test_all([100, 0, 100], 100)\n\n    def test_large_input(self):\n        """较大输入 — 验证性能"""\n        n = 10000\n        height = [0] * n\n        for i in range(n):\n            height[i] = i if i < n // 2 else n - i - 1\n        # 这个三角形状：左边上升右边下降，顶部在中间，整体形成"山峰"\n        # 接水为 0（因为单调）\n        self._test_all(height, 0)\n\n    # ---- 随机验证：三种解法结果应完全一致 ----\n    def test_consistency_random(self):\n        """随机数组三种解法结果一致"""\n        import random\n        random.seed(42)\n        for _ in range(100):\n            n = random.randint(0, 50)\n            heights = [random.randint(0, 20) for _ in range(n)]\n            r1 = trap_two_pointer(heights)\n            r2 = trap_dp(heights)\n            r3 = trap_monotonic_stack(heights)\n            self.assertEqual(r1, r2, f"two_pointer vs dp: {heights}")\n            self.assertEqual(r2, r3, f"dp vs stack: {heights}")\n\n\nif __name__ == "__main__":\n    # 用 unittest 运行并捕获结果\n    loader = unittest.TestLoader()\n    suite = loader.loadTestsFromTestCase(TestTrappingRainWater)\n    runner = unittest.TextTestRunner(verbosity=2)\n    result = runner.run(suite)\n    print(f"\\n{\'=\'*40}")\n    print(f"Tests run: {result.testsRun}")\n    print(f"Failures: {len(result.failures)}")\n    print(f"Errors:   {len(result.errors)}")'}
