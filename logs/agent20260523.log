2026-05-23 01:10:54,694 - DEBUG - middleware.py:102 - agent - [monitor_tool] 传入参数: {'code': 'from typing import List\n\n\ndef trap_two_pointer(height: List[int]) -> int:\n    """双指针解法 — 时间 O(n)，空间 O(1)，推荐"""\n    if not height:\n        return 0\n\n    left, right = 0, len(height) - 1\n    left_max = right_max = 0\n    water = 0\n\n    while left < right:\n        left_max = max(left_max, height[left])\n        right_max = max(right_max, height[right])\n\n        if left_max < right_max:\n            water += left_max - height[left]\n            left += 1\n        else:\n            water += right_max - height[right]\n            right -= 1\n\n    return water\n\n\ndef trap_dp(height: List[int]) -> int:\n    """动态规划解法 — 时间 O(n)，空间 O(n)，直观易理解"""\n    n = len(height)\n    if n == 0:\n        return 0\n\n    # left_max[i]: height[0..i] 的最大值\n    left_max = [0] * n\n    left_max[0] = height[0]\n    for i in range(1, n):\n        left_max[i] = max(left_max[i - 1], height[i])\n\n    # right_max[i]: height[i..n-1] 的最大值\n    right_max = [0] * n\n    right_max[-1] = height[-1]\n    for i in range(n - 2, -1, -1):\n        right_max[i] = max(right_max[i + 1], height[i])\n\n    # 每个位置的水量 = min(left_max, right_max) - height\n    water = 0\n    for i in range(n):\n        water += min(left_max[i], right_max[i]) - height[i]\n\n    return water\n\n\ndef trap_monotonic_stack(height: List[int]) -> int:\n    """单调递减栈解法 — 时间 O(n)，空间 O(n)，逐层计算"""\n    stack: List[int] = []\n    water = 0\n\n    for i, h in enumerate(height):\n        # 当前柱子比栈顶高 → 形成凹槽\n        while stack and h > height[stack[-1]]:\n            bottom_idx = stack.pop()\n            if not stack:\n                break\n            left_idx = stack[-1]\n            # 宽度 × 有效高度\n            width = i - left_idx - 1\n            bounded_height = min(height[left_idx], h) - height[bottom_idx]\n            water += width * bounded_height\n        stack.append(i)\n\n    return water\n\n\n# ========== 默认对外接口 ==========\ntrap = trap_two_pointer  # 默认使用最优解\n\nprint("✅ 所有函数定义成功")\nprint(f"  trap           → {trap.__doc__}")\nprint(f"  trap_dp        → {trap_dp.__doc__}")\nprint(f"  trap_two_pointer → {trap_two_pointer.__doc__}")\nprint(f"  trap_monotonic_stack → {trap_monotonic_stack.__doc__}")'}
