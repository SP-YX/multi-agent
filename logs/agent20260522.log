2026-05-22 19:34:47,670 - INFO - middleware.py:102 - agent - [monitor_tool] 传入参数: {'code': 'from typing import List\nimport logging\n\nlogging.basicConfig(level=logging.INFO, format="%(levelname)s: %(message)s")\nlogger = logging.getLogger(__name__)\n\n\nclass TrappingRainWater:\n    """接雨水算法 —— 多种实现"""\n\n    @staticmethod\n    def trap_two_pointers(height: List[int]) -> int:\n        """\n        双指针法: O(n) 时间, O(1) 空间\n\n        核心思想：\n        - 左指针从 0 开始，右指针从末尾开始\n        - 维护 left_max 和 right_max\n        - 每次移动较矮一侧的指针（因为较矮的一侧决定了当前能接的水量）\n        - 水量 = 该侧 max - 当前高度\n\n        Args:\n            height: 高度数组\n\n        Returns:\n            能接的雨水总量\n\n        Examples:\n            >>> TrappingRainWater.trap_two_pointers([0,1,0,2,1,0,1,3,2,1,2,1])\n            6\n            >>> TrappingRainWater.trap_two_pointers([4,2,0,3,2,5])\n            9\n        """\n        if not height:\n            return 0\n\n        left, right = 0, len(height) - 1\n        left_max, right_max = 0, 0\n        total_water = 0\n\n        while left < right:\n            if height[left] < height[right]:\n                # 左侧较矮，处理左指针\n                if height[left] >= left_max:\n                    left_max = height[left]\n                else:\n                    total_water += left_max - height[left]\n                left += 1\n            else:\n                # 右侧较矮或相等，处理右指针\n                if height[right] >= right_max:\n                    right_max = height[right]\n                else:\n                    total_water += right_max - height[right]\n                right -= 1\n\n        return total_water\n\n    @staticmethod\n    def trap_dp(height: List[int]) -> int:\n        """\n        动态规划法: O(n) 时间, O(n) 空间\n\n        预处理 left_max[i] 和 right_max[i]:\n        - left_max[i]  = max(height[0..i])\n        - right_max[i] = max(height[i..n-1])\n        - water[i] = min(left_max[i], right_max[i]) - height[i]\n\n        Args:\n            height: 高度数组\n\n        Returns:\n            能接的雨水总量\n        """\n        n = len(height)\n        if n == 0:\n            return 0\n\n        # 预处理左侧最高\n        left_max = [0] * n\n        left_max[0] = height[0]\n        for i in range(1, n):\n            left_max[i] = max(left_max[i - 1], height[i])\n\n        # 预处理右侧最高\n        right_max = [0] * n\n        right_max[n - 1] = height[n - 1]\n        for i in range(n - 2, -1, -1):\n            right_max[i] = max(right_max[i + 1], height[i])\n\n        # 计算总水量\n        total_water = 0\n        for i in range(n):\n            water_at_i = min(left_max[i], right_max[i]) - height[i]\n            if water_at_i > 0:\n                total_water += water_at_i\n\n        return total_water\n\n    @staticmethod\n    def trap_monotonic_stack(height: List[int]) -> int:\n        """\n        单调递减栈法: O(n) 时间, O(n) 空间\n\n        维护一个单调递减栈（存下标），遇到"凹槽"时计算水量。\n        适合需要知道每个凹槽具体蓄水量的场景。\n\n        Args:\n            height: 高度数组\n\n        Returns:\n            能接的雨水总量\n        """\n        n = len(height)\n        if n == 0:\n            return 0\n\n        stack: List[int] = []  # 存下标，对应高度单调递减\n        total_water = 0\n\n        for i in range(n):\n            # 当前高度 > 栈顶高度 → 形成凹槽，可以接水\n            while stack and height[i] > height[stack[-1]]:\n                bottom_idx = stack.pop()  # 凹槽底部\n                if not stack:\n                    break  # 左边没有墙壁\n                left_idx = stack[-1]  # 左墙壁\n                # 宽度 = 右墙壁 i - 左墙壁 left_idx - 1\n                width = i - left_idx - 1\n                # 高度 = min(左墙, 右墙) - 底部\n                bounded_height = min(height[left_idx], height[i]) - height[bottom_idx]\n                total_water += width * bounded_height\n            stack.append(i)\n\n        return total_water\n\n\n# ─────────────────────── 测试 ───────────────────────\n\ndef run_tests():\n    """运行所有测试用例"""\n    test_cases = [\n        # (输入, 期望输出, 描述)\n        ([0, 1, 0, 2, 1, 0, 1, 3, 2, 1, 2, 1], 6, "经典案例"),\n        ([4, 2, 0, 3, 2, 5], 9, "中等案例"),\n        ([1, 1, 1, 1], 0, "完全平坦"),\n        ([5, 4, 3, 2, 1], 0, "严格递减"),\n        ([1, 2, 3, 4, 5], 0, "严格递增"),\n        ([3, 0, 0, 0, 3], 9, "深凹槽"),\n        ([], 0, "空数组"),\n        ([1], 0, "单元素"),\n        ([2, 0, 2], 2, "简单凹槽"),\n        ([5, 1, 0, 2, 1, 0, 1, 3, 2, 1, 2, 1], 19, "复杂案例"),\n    ]\n\n    methods = [\n        ("双指针", TrappingRainWater.trap_two_pointers),\n        ("动态规划", TrappingRainWater.trap_dp),\n        ("单调栈", TrappingRainWater.trap_monotonic_stack),\n    ]\n\n    all_passed = True\n    for name, method in methods:\n        print(f"\\n{\'=\'*50}")\n        print(f"测试方法: {name}")\n        print(f"{\'=\'*50}")\n        passed = 0\n        for height, expected, desc in test_cases:\n            try:\n                result = method(height)\n                status = "✅" if result == expected else "❌"\n                if result == expected:\n                    passed += 1\n                else:\n                    all_passed = False\n                print(f"  {status} {desc}: height={height} → {result} (期望={expected})")\n            except Exception as e:\n                print(f"  ❌ {desc}: 异常 - {e}")\n                all_passed = False\n        print(f"  通过: {passed}/{len(test_cases)}")\n\n    print(f"\\n{\'=\'*50}")\n    print(f"总结: {\'全部通过 🎉\' if all_passed else \'存在失败 ❌\'}")\n    print(f"{\'=\'*50}")\n\n    return all_passed\n\n\nif __name__ == "__main__":\n    run_tests()'}
